<?xml version="1.0"?>
<launch>
  <!-- YOLOv5 ROS Launch File with TensorRT - High Resolution Optimized -->
  
  <!-- Arguments for high performance with 3264x2464 resolution -->
  <arg name="weights" default="$(find yolov5_ros)/../weights/yolov5s.pt" />
  <arg name="device" default="0" />
  <arg name="conf_thres" default="0.4" />
  <arg name="iou_thres" default="0.45" />
  <arg name="imgsz" default="416" />  <!-- 降低推理分辨率以提升速度 -->
  <arg name="half" default="true" />
  <arg name="use_trt" default="true" />
  <arg name="camera_width" default="3264" />
  <arg name="camera_height" default="2464" />
  <arg name="camera_fps" default="10" />  <!-- 进一步降低帧率以适应高分辨率 -->
  <arg name="visualize" default="false" />
  <arg name="publish_image" default="false" />
  <arg name="save_debug_images" default="false" />
  
  <!-- Camera Node -->
  <node name="yolov5_camera" pkg="yolov5_ros" type="yolov5_camera_node.py" output="screen">
    <param name="width" value="$(arg camera_width)" />
    <param name="height" value="$(arg camera_height)" />
    <param name="fps" value="$(arg camera_fps)" />
    <param name="sensor_id" value="0" />
    <param name="image_topic" value="/camera/image_raw" />
    <param name="camera_info_topic" value="/camera/camera_info" />
    <param name="frame_id" value="camera_link" />
  </node>
  
  <!-- YOLOv5 Detection Node with TensorRT (High Resolution Optimized) -->
  <node name="yolov5_detection" pkg="yolov5_ros" type="yolov5_detection_node.py" output="screen">
    <!-- Model parameters -->
    <param name="weights" value="$(arg weights)" />
    <param name="device" value="$(arg device)" />
    <param name="conf_thres" value="$(arg conf_thres)" />
    <param name="iou_thres" value="$(arg iou_thres)" />
    <param name="imgsz" value="$(arg imgsz)" />
    <param name="half" value="$(arg half)" />
    <param name="use_trt" value="$(arg use_trt)" />
    <param name="agnostic_nms" value="false" />
    
    <!-- Performance optimized topics -->
    <param name="image_topic" value="/camera/image_raw" />
    <param name="detection_topic" value="/yolov5/detections" />
    <param name="visualize" value="$(arg visualize)" />
    <param name="publish_image" value="$(arg publish_image)" />
    <param name="save_debug_images" value="$(arg save_debug_images)" />
  </node>
  
</launch>